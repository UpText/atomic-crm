<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build">
  <Sdk Name="Microsoft.Build.Sql" Version="2.1.0" />
  <PropertyGroup>
    <Name>DbProjAtomicCrm</Name>
    <ProjectGuid>{9F2820E4-8CD0-4FDE-8F82-EDCE7B1516E8}</ProjectGuid>
    <DSP>Microsoft.Data.Tools.Schema.Sql.SqlAzureV12DatabaseSchemaProvider</DSP>
    <ModelCollation>1033, CI</ModelCollation>
  </PropertyGroup>
  <ItemGroup>
    <Build Remove="DbProjAtomicCrm.sql" />
    <Build Remove="ImportSnapshot\**\*.sql" />
    <Build Remove="Generated\**\*.sql" />
    <Build Remove="dist\**\*.sql" />
    <Build Remove=".sqlpackage\**\*.sql" />
  </ItemGroup>
  <ItemGroup>
    <SqlCmdVariable Include="DeployVersion">
      <DefaultValue>manual</DefaultValue>
      <Value>$(SqlCmdVar__1)</Value>
    </SqlCmdVariable>
    <SqlCmdVariable Include="GitCommit">
      <DefaultValue>unknown</DefaultValue>
      <Value>$(SqlCmdVar__2)</Value>
    </SqlCmdVariable>
    <SqlCmdVariable Include="DeployedBy">
      <DefaultValue>unknown</DefaultValue>
      <Value>$(SqlCmdVar__3)</Value>
    </SqlCmdVariable>
    <SqlCmdVariable Include="DeploymentTarget">
      <DefaultValue>unknown</DefaultValue>
      <Value>$(SqlCmdVar__4)</Value>
    </SqlCmdVariable>
    <SqlCmdVariable Include="ServiceUserName">
      <DefaultValue></DefaultValue>
      <Value>$(SqlCmdVar__5)</Value>
    </SqlCmdVariable>
    <SqlCmdVariable Include="ServiceUserPassword">
      <DefaultValue></DefaultValue>
      <Value>$(SqlCmdVar__6)</Value>
    </SqlCmdVariable>
    <PreDeploy Include="PreDeploy.sql" />
    <PostDeploy Include="PostDeploy.sql" />
  </ItemGroup>
  <Target Name="BeforeBuild">
    <Delete Files="$(BaseIntermediateOutputPath)\project.assets.json" />
  </Target>
</Project>
